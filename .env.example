# Environment variables (example)

# Optional: Stripe API secret key. If not provided, Stripe features are disabled.
STRIPE_SECRET_KEY=sk_test_xxx

# Optional: MongoDB connection string. If not provided, the app will return seeded demo data.
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/ai-auto-clipper

# Optional: JWT secret (if you enable auth later)
JWT_SECRET=your_jwt_secret

# Port the server listens on (default 3000)
PORT=3000

# SMTP config for nodemailer (optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=supersecret
